# 2277 - if else (optimized)
# Read two characters and output '1' if same, '0' if different

# Read inputs directly into registers
A<I
B<I

# Set memory[B] = 49 ('1')
[B]<49

# Try to load from memory[A]
# If A == B, we get 49
# If A != B, we get whatever was there (likely 0)
D<[A]

# If D is 0, output 48 ('0'), otherwise output D
# We need to handle the case where D might be 0
# If D == 0, set D to 48
# We can use conditional logic via memory

# Actually, if memory is initialized to 0, and we set [B] to 49,
# then [A] will be 49 if A==B, else 0
# We need to convert 0 to 48 ('0')

# Strategy: use memory[49] = 49 and memory[0] = 48
[0]<48
[49]<49

# Set [B] to 49
[B]<49

# Load [A] - this is either 49 or 0
D<[A]

# Output D if D != 0, else output 48
# Use D to index: output mem[D]
# mem[0] = 48, mem[49] = 49
O<[D]

Z<1
